// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    }
  },
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      "ctrl-j": null
    }
  },
  {
    "context": "Workspace || Editor",
    "bindings": {
      "ctrl-j": "terminal_panel::Toggle"
    }
  },
  {
    "context": "vim_mode == literal",
    "bindings": {
      "ctrl-j": null
    }
  },
  {
    "context": "((FileFinder || FileFinder > Picker > Editor) || FileFinder > Picker > menu)",
    "bindings": {
      "ctrl-j": null
    }
  },
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      "ctrl-b": null
    }
  },
  {
    "context": "vim_mode == literal",
    "bindings": {
      "ctrl-b": null
    }
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "ctrl-e": null
    }
  },
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      "ctrl-e": null
    }
  },
  {
    "context": "showing_completions",
    "bindings": {
      "ctrl-e": null
    }
  },
  {
    "context": "Editor && vim_mode == normal && vim_operator == none && !VimWaiting",
    "bindings": {
      "space e": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "space e": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-n": "workspace::NewTerminal",
      "cmd-d": "pane::CloseActiveItem",
      "cmd-t": "workspace::ToggleBottomDock",
      "cmd-shift-f": "workspace::ToggleZoom",
      "escape": "workspace::ToggleBottomDock"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "g b": [
        "editor::SelectNext",
        {
          "replace_newest": false
        }
      ]
    }
  },
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      "g shift-a": null
    }
  },
  {
    "context": "(VimControl && !menu)",
    "bindings": {
      "g r": "editor::FindAllReferences"
    }
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "ctrl-space": "editor::ShowCompletions"
    }
  },
  {
    "context": "KeymapEditor",
    "bindings": {
      "ctrl-t": null
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-t": "workspace::NewTerminal"
    }
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "ctrl-v": "editor::Paste"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-l": "agent::ToggleFocus"
    }
  }
]
